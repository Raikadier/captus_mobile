# ── Captus Mobile — Environment Variables ─────────────────────────────────────
#
# Copy this file to .env and fill in the values.
# NEVER commit .env — it contains secrets.
# .env is already in .gitignore.
#
# Get values from:
#   Supabase  → https://supabase.com/dashboard/project/<id>/settings/api
#   Backend   → ask the team for the staging/production URL

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_ANON_KEY=<supabase-anon-key>

# ── Backend REST API ───────────────────────────────────────────────────────────
# Local development (Android emulator)
# API_BASE_URL=http://10.0.2.2:3000/api
#
# Local development (physical device — use your machine's LAN IP)
# API_BASE_URL=http://192.168.x.x:3000/api
#
# Production
API_BASE_URL=https://captus-backend.vercel.app/api
